# Server
NODE_ENV=development
PORT=5000

# Database (local docker-compose)
DB_HOST=mysql
DB_PORT=3306
DB_NAME=appdb
DB_USER=appuser
DB_PASSWORD=apppassword

# When deployed on AWS, set DB_HOST to your RDS endpoint, e.g.:
# DB_HOST=mydb.abc123xyz.ap-south-1.rds.amazonaws.com

# CORS - frontend origin allowed to call this API
CORS_ORIGIN=http://localhost:3000
