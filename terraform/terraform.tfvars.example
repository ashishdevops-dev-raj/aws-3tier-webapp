# Copy to terraform.tfvars and fill in real values.
# DO NOT commit terraform.tfvars (it contains the DB password).

aws_region   = "ap-south-1"
project_name = "threetier"
environment  = "dev"

# Existing EC2 key pair name in this region (create one in AWS Console -> EC2 -> Key Pairs)
key_pair_name = "my-keypair"

# Your public IP for SSH (run `curl ifconfig.me` and append /32)
ssh_allowed_cidr = "203.0.113.10/32"

# DB master password (min 8 chars, no slashes/quotes/@)
db_password = "ChangeMeStrong#2026"

# Free Tier mode: keep this FALSE. Set TRUE for true 3-tier private backend.
enable_nat_gateway = false
